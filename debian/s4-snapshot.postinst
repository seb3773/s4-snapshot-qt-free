mkdir -p /usr/share/s4-snapshot /usr/share/excludes
ln -fs /usr/share/s4-snapshot/s4-snapshot-exclude.list /usr/share/excludes/s4-snapshot-exclude.list

#cleanup old links

if [ -e /usr/share/local/excludes/s4-snapshot-exclude.list ]; then
    rm -f /usr/share/local/excludes/s4-snapshot-exclude.list
fi
